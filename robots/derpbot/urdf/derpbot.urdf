<?xml version="1.0"?>
<!--
  DerpBot — simple two-wheeled differential drive robot.

  Layout (top view):

          front (+x)
             ↑
     ┌───────────────┐
     │       ●       │  ← front caster sphere r=0.02 at x=+0.13
     │               │  ← body: 0.30 × 0.20 × 0.10 m (L × W × H)
     │       ●       │  ← rear caster sphere r=0.02 at x=-0.13
     └───────────────┘
    ○               ○   ← wheels r=0.05, w=0.03, geometric separation 0.23 m
                         (effective kinematic track width 0.20 m — calibrated in sim)

  Coordinate convention:
    base_footprint  — at ground level (z=0), this is the spawn frame
    base_link       — at z=0.05 (wheel axle height), body centre
    left_wheel      — at (0, +0.115, 0) relative to base_link
    right_wheel     — at (0, -0.115, 0) relative to base_link
    caster_wheel      — at (+0.13, 0, -0.03) relative to base_link → z=0.02 world
    rear_caster_wheel — at (-0.13, 0, -0.03) relative to base_link → z=0.02 world

  Sensors: contact/bumper on base_link (detects all sides).  Bounding-box camera on top-front.
           RGBD camera on top-front (z=+0.20 rel to base_link) — RGB + depth.
           2D LiDAR (gpu_lidar) on top of body at z=+0.12 rel to base_link.
           IMU at body centre z=+0.05 rel to base_link.

  Visual: yellow strip on front face (+x) marks forward direction.

  Gazebo plugins (Harmonic):
    gz-sim-diff-drive-system        — velocity control + odometry
    gz-sim-joint-state-publisher-system — joint state publication
    gpu_lidar sensor                — 720-ray 360° scan → /ROBOT_NAME/scan
    imu sensor                      — 100 Hz IMU → /ROBOT_NAME/imu
-->
<robot name="derpbot">

  <!-- ═══════════════════════════ BASE STRUCTURE ════════════════════════════ -->

  <!-- Minimal inertial prevents gz sdf from lumping base_footprint+base_link
       into one link and renaming the collision.  Without this, the contact
       sensor can't find its collision by name after the rename. -->
  <link name="base_footprint">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.30 0.20 0.10"/>
      </geometry>
      <material name="derpbot_blue">
        <color rgba="0.20 0.40 0.90 1.0"/>
      </material>
    </visual>
    <!-- Yellow strip on front face (+x = forward) so you can read the robot's heading -->
    <visual name="front_indicator">
      <origin xyz="0.151 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.005 0.20 0.10"/>
      </geometry>
      <material name="indicator_yellow">
        <color rgba="1.0 0.85 0.0 1.0"/>
      </material>
    </visual>
    <collision name="base_link_collision">
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.30 0.20 0.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="1.5"/>
      <!-- Box inertia: m/12*(b²+c²), m/12*(a²+c²), m/12*(a²+b²) for a×b×c=0.30×0.20×0.10 -->
      <inertia ixx="0.00625" ixy="0.0" ixz="0.0"
               iyy="0.01250" iyz="0.0"
               izz="0.01625"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════ LEFT WHEEL ════════════════════════════════ -->
  <!--  joint origin: (0, +0.115, 0) rel to base_link → wheel centre at z=0.05 world
        rpy=-pi/2 rotates cylinder so its rolling axis aligns with world-y              -->

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.115 0" rpy="-1.5707963 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
      <material name="wheel_dark">
        <color rgba="0.15 0.15 0.15 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <!-- Cylinder (axis=z in link frame): Ixx=Iyy=m/12*(3r²+h²), Izz=m/2*r²
           r=0.05, h=0.03: Ixx=0.2/12*(0.0075+0.0009)=0.000140, Izz=0.1*0.0025=0.000250 -->
      <inertia ixx="0.000140" ixy="0.0" ixz="0.0"
               iyy="0.000140" iyz="0.0"
               izz="0.000250"/>
    </inertial>
  </link>

  <!-- ══════════════════════════ RIGHT WHEEL ════════════════════════════════ -->

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.115 0" rpy="-1.5707963 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
      <material name="wheel_dark">
        <color rgba="0.15 0.15 0.15 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.000140" ixy="0.0" ixz="0.0"
               iyy="0.000140" iyz="0.0"
               izz="0.000250"/>
    </inertial>
  </link>

  <!-- ════════════════════════ CASTER WHEELS (front + rear) ════════════════ -->
  <!--  Two casters provide stable 4-point contact and prevent pitch under
        acceleration.  Both spheres r=0.02, joints at z=-0.03 rel to base_link
        → sphere centres at z = 0.05 - 0.03 = 0.02 world (just touching ground). -->

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.13 0 -0.03" rpy="0 0 0"/>
  </joint>

  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="caster_grey">
        <color rgba="0.50 0.50 0.50 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <!-- Solid sphere: I = 2/5*m*r² = 0.4*0.05*0.0004 = 0.000008 -->
      <inertia ixx="0.000008" ixy="0.0" ixz="0.0"
               iyy="0.000008" iyz="0.0"
               izz="0.000008"/>
    </inertial>
  </link>

  <joint name="rear_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_caster_wheel"/>
    <origin xyz="-0.13 0 -0.03" rpy="0 0 0"/>
  </joint>

  <link name="rear_caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="caster_grey">
        <color rgba="0.50 0.50 0.50 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000008" ixy="0.0" ixz="0.0"
               iyy="0.000008" iyz="0.0"
               izz="0.000008"/>
    </inertial>
  </link>

  <!-- ════════════════════════ BOUNDING-BOX CAMERA ══════════════════════════ -->
  <!--  Forward-facing camera mounted on top of the robot body.
        Position: x=+0.05 m (10 cm behind front collision face), z=+0.15 m
        relative to base_link.  Kept well inside the robot body so the camera
        cannot clip through a wall even when the robot is firmly pressed against it.
        Faces forward along robot +x with no tilt.
        ROBOT_NAME is replaced at spawn/generation time.                      -->

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- z=0.20: camera is 10 cm above body top (body top = 0.10 from base_link).
         At bottom FOV edge (−36.87°) the ray hits body-top plane at x=0.183 m
         from base_link, which is outside the body's ±0.15 m x-extent — body
         invisible in frame.  Previously z=0.15 put the ray at x=0.117 (inside
         body), causing the lower ~25 % of the image to show the blue chassis. -->
    <origin xyz="0.05 0 0.20" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <!-- Small box visual so the camera mount is visible in Gazebo GUI -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
      <material name="camera_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <!-- Minimal inertia — fixed joint, not dynamic -->
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <!-- ════════════════════════ GAZEBO PLUGINS ═══════════════════════════════ -->

  <gazebo>
    <!-- Differential drive: subscribes cmd_vel, publishes odom + TF.
         ROBOT_NAME is a placeholder replaced at spawn time by spawn_robot.launch.py
         with the actual robot instance name (e.g. "derpbot_0").
         Using absolute Gazebo topic names (leading /) so ros_gz_bridge can use
         the same names on the ROS 2 side without any --remap gymnastics. -->
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <!-- Geometric centre-to-centre is 0.23 m (joints at y=±0.115).
           Gazebo Harmonic contact physics gives an effective kinematic track
           width of 0.20 m — equal to the inner face-to-face separation of the
           wheel cylinders (±0.100 m).  Using the uncalibrated 0.23 m here
           causes angular over-shoot (~15 %); using 0.20 m makes odom match
           ground-truth rotation empirically (measured: GT/odom ≈ 0.865 with
           0.1725, corrected to 0.20 m). -->
      <wheel_separation>0.20</wheel_separation>
      <wheel_radius>0.05</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>/ROBOT_NAME/cmd_vel</topic>
      <odom_topic>/ROBOT_NAME/odom</odom_topic>
      <tf_topic>/ROBOT_NAME/tf</tf_topic>
      <!-- TF frame IDs: unprefixed (standard single-robot convention).
           For multi-robot, these would need per-instance prefixes too. -->
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <max_linear_acceleration>0.5</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
    </plugin>

    <!-- Joint state publisher: publishes wheel angles for robot_state_publisher -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/ROBOT_NAME/joint_states</topic>
    </plugin>
  </gazebo>

  <!-- ══════════════════════════ BUMPER SENSOR ══════════════════════════════ -->
  <!-- Contact sensor.  Publishes ros_gz_interfaces/Contacts to
       /ROBOT_NAME/bumper_contact (ROBOT_NAME substituted at spawn time).
       Requires gz-sim-contact-system in the world (already present).

       IMPORTANT: gz sdf -p lumps the base_footprint→base_link fixed joint,
       merging base_link into base_footprint and renaming the collision from
       "base_link_collision" to the mangled name below.  The sensor's
       <collision> must match this exact post-lumping ECS entity name, or the
       contact system cannot find the collision and never initializes the
       gz transport publisher (symptom: "no publishers" on the topic).

       To regenerate this name:  gz sdf -p robots/derpbot/urdf/derpbot.urdf | grep collision  -->

  <gazebo reference="base_footprint">
    <sensor name="bumper" type="contact">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <topic>/ROBOT_NAME/bumper_contact</topic>
      <contact>
        <collision>base_footprint_fixed_joint_lump__base_link_collision_collision</collision>
        <topic>/ROBOT_NAME/bumper_contact</topic>
      </contact>
    </sensor>
  </gazebo>

  <!-- ── Bounding-box camera ────────────────────────────────────────────── -->
  <!--  Outputs gz.msgs.AnnotatedAxisAligned2DBox_V, bridged via ros_gz_bridge
        to vision_msgs/Detection2DArray on /ROBOT_NAME/detections.
        Requires gz-sim-label-system at model level on target objects (already
        present in worlds/models/*/model.sdf).
        The camera renders in the +x direction of camera_link (forward on
        DerpBot) — matches the forward-facing joint origin above.           -->
  <gazebo reference="camera_link">
    <!-- Bounding-box camera: object detection (bridged to vision_msgs/Detection2DArray) -->
    <sensor name="bbox_camera" type="boundingbox_camera">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <topic>/ROBOT_NAME/detections</topic>
      <camera name="bbox_camera">
        <!-- 90 degrees -->
        <horizontal_fov>1.5708</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <!-- near=0.05: camera is 0.10 m from front face; wall face renders at
               0.10 m > 0.05 m so walls always occlude objects behind them. -->
          <near>0.05</near>
          <far>100.0</far>
        </clip>
      </camera>
      <visualize>false</visualize>
    </sensor>

    <!-- RGBD camera: RGB + depth for agent perception pipelines.
         Base topic /ROBOT_NAME/rgbd publishes:
           /ROBOT_NAME/rgbd             — RGB image  (sensor_msgs/Image)
           /ROBOT_NAME/rgbd/depth_image — depth map  (float32 metres)
           /ROBOT_NAME/rgbd/points      — point cloud (PointCloud2, optional bridge)
           /ROBOT_NAME/rgbd/camera_info — intrinsics  (sensor_msgs/CameraInfo)
         Depth clip 0.15–6.0 m matches RealSense-class hardware.
         Depth noise: Gaussian stddev 0.01 m (≈1 % at 1 m).               -->
    <sensor name="rgbd_camera" type="rgbd_camera">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <topic>/ROBOT_NAME/rgbd</topic>
      <gz_frame_id>camera_link</gz_frame_id>
      <camera name="rgbd_camera">
        <!-- Same FOV/resolution as bbox_camera so views align -->
        <horizontal_fov>1.5708</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <!-- near=0.15: matches realistic RGBD sensor minimum depth.
               far=100.0: unlimited RGB rendering; depth range is controlled
               separately by depth_camera/clip below (6 m). -->
          <near>0.15</near>
          <far>100.0</far>
        </clip>
        <depth_camera>
          <output>depths</output>
          <clip>
            <near>0.15</near>
            <far>6.0</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </depth_camera>
      </camera>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- ════════════════════════════ LIDAR ═══════════════════════════════════ -->
  <!--  2-D 360° LiDAR mounted on top of robot body.
        lidar_joint at (0, 0, +0.12) rel to base_link.
        base_link is at z=0.05 world, body top is at z=0.15 world
        → lidar centre at z = 0.05 + 0.12 = 0.17 m world (2 cm above body).
        ROBOT_NAME is substituted at spawn/generation time.                  -->

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <!-- Cylinder visual: r=0.04 m, h=0.04 m — typical spinning-lidar drum -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <material name="lidar_black">
        <color rgba="0.10 0.10 0.10 1.0"/>
      </material>
    </visual>
    <!-- Minimal inertia — fixed joint, mass negligible for dynamics -->
    <inertial>
      <mass value="0.1"/>
      <!-- Cylinder Ixx=Iyy=m/12*(3r²+h²)=0.1/12*(0.0048+0.0016)=0.0000533
           Izz=m/2*r²=0.05*0.0016=0.000080                               -->
      <inertia ixx="0.000053" ixy="0" ixz="0"
               iyy="0.000053" iyz="0"
               izz="0.000080"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════ IMU ══════════════════════════════════ -->
  <!--  IMU placed at body centre.
        imu_joint at (0, 0, +0.05) rel to base_link → at body CoM.
        No collision/visual — internal chip.                                 -->

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>

  <!-- ═══════════════════ LIDAR GAZEBO SENSOR ══════════════════════════════ -->
  <!--  gpu_lidar: 360° horizontal, 720 samples, 10 Hz, range 0.15–12 m.
        Requires gz-sim-sensors-system (ogre2) — already in world.sdf.
        gz_frame_id overrides the default scoped-name frame to "lidar_link"
        so the ROS 2 LaserScan header.frame_id matches the URDF link name.  -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <topic>/ROBOT_NAME/scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle>3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- ════════════════════ IMU GAZEBO SENSOR ═══════════════════════════════ -->
  <!--  IMU: 100 Hz, light Gaussian noise (consumer-grade MEMS model).
        gz_frame_id sets header.frame_id = "imu_link" in bridged ROS message. -->
  <gazebo reference="imu_link">
    <sensor name="imu" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>/ROBOT_NAME/imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></z>
        </linear_acceleration>
      </imu>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- Frictionless casters so they don't resist turning -->
  <gazebo reference="caster_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="rear_caster_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <!-- Drive wheels: good traction -->
  <gazebo reference="left_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
  </gazebo>

</robot>
