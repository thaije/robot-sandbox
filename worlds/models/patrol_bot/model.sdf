<?xml version="1.0"?>
<!--
  Patrol Bot — lightweight dynamic obstacle for ARST hard/brutal tiers.

  Layout:
    Disc chassis   r=0.25 m, h=0.12 m   (blue-grey cylinder)
    Drive wheels   r=0.10 m, w=0.04 m  at y=±0.28 m, z=-0.04 m
    Front caster   r=0.04 m sphere      at x=+0.20 m, z=-0.08 m

  Controlled by patrol_bot_controller.py via gz-transport topic:
    /model/<name>/cmd_vel   (gz.msgs.Twist)

  WorldGenerator sets the spawn pose and unique model name at generation time.
  No ROS bridge needed — controller uses gz-transport directly.
-->
<sdf version="1.9">
  <model name="patrol_bot">

    <!-- ── Chassis ──────────────────────────────────────────────────────────── -->
    <link name="base_link">
      <inertial>
        <mass>8.0</mass>
        <inertia>
          <ixx>0.30</ixx><iyy>0.30</iyy><izz>0.50</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.25</radius><length>0.12</length></cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.25</radius><length>0.12</length></cylinder>
        </geometry>
        <material>
          <ambient>0.25 0.30 0.70 1</ambient>
          <diffuse>0.30 0.35 0.80 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- ── Left wheel (y+) ───────────────────────────────────────────────── -->
    <link name="left_wheel">
      <pose>0 0.28 -0.04 -1.5707963 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0013</ixx><iyy>0.0013</iyy><izz>0.0025</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.10</radius><length>0.04</length></cylinder>
        </geometry>
        <surface><friction><ode>
          <mu>1.0</mu><mu2>0.5</mu2>
        </ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.10</radius><length>0.04</length></cylinder>
        </geometry>
        <material>
          <ambient>0.08 0.08 0.08 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <!-- Wheel spin axis = Y in model frame (left-right), expressed in model frame -->
        <xyz expressed_in="__model__">0 1 0</xyz>
        <dynamics><friction>0.01</friction><damping>0.01</damping></dynamics>
        <limit><lower>-1e9</lower><upper>1e9</upper><effort>1e6</effort></limit>
      </axis>
    </joint>

    <!-- ── Right wheel (y-) ──────────────────────────────────────────────── -->
    <link name="right_wheel">
      <pose>0 -0.28 -0.04 1.5707963 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0013</ixx><iyy>0.0013</iyy><izz>0.0025</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder><radius>0.10</radius><length>0.04</length></cylinder>
        </geometry>
        <surface><friction><ode>
          <mu>1.0</mu><mu2>0.5</mu2>
        </ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder><radius>0.10</radius><length>0.04</length></cylinder>
        </geometry>
        <material>
          <ambient>0.08 0.08 0.08 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <dynamics><friction>0.01</friction><damping>0.01</damping></dynamics>
        <limit><lower>-1e9</lower><upper>1e9</upper><effort>1e6</effort></limit>
      </axis>
    </joint>

    <!-- ── Front caster ──────────────────────────────────────────────────── -->
    <link name="caster">
      <pose>0.20 0 -0.08 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><sphere><radius>0.04</radius></sphere></geometry>
        <surface><friction><ode>
          <mu>0.0</mu><mu2>0.0</mu2>
        </ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry><sphere><radius>0.04</radius></sphere></geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.20 0.20 0.20 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="caster_joint" type="ball">
      <parent>base_link</parent>
      <child>caster</child>
    </joint>

    <!-- ── Rear caster ───────────────────────────────────────────────────── -->
    <link name="caster_rear">
      <pose>-0.20 0 -0.08 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry><sphere><radius>0.04</radius></sphere></geometry>
        <surface><friction><ode>
          <mu>0.0</mu><mu2>0.0</mu2>
        </ode></friction></surface>
      </collision>
      <visual name="visual">
        <geometry><sphere><radius>0.04</radius></sphere></geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.20 0.20 0.20 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="caster_rear_joint" type="ball">
      <parent>base_link</parent>
      <child>caster_rear</child>
    </joint>

    <!-- ── DiffDrive plugin ───────────────────────────────────────────────── -->
    <!-- No <topic> element: DiffDrive defaults to /model/<name>/cmd_vel.
         This matches what patrol_bot_controller.py publishes to.
         Specifying <topic>cmd_vel</topic> would resolve to /cmd_vel (global),
         which is the wrong topic and why the bot never moved. -->
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.56</wheel_separation>
      <wheel_radius>0.10</wheel_radius>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <min_linear_acceleration>-1.0</min_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <min_angular_acceleration>-2.0</min_angular_acceleration>
    </plugin>

  </model>
</sdf>
